{
  "name": "ecommerce-qwik-resumability",
  "description": "Qwik e-commerce demo with full Resumability",
  "version": "1.0.0",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "private": true,
  "trustedDependencies": [
    "@builder.io/qwik"
  ],
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/express/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "build.production": "npm run build.types && npm run build.client && npm run build.server",
    "deploy": "echo 'Run \"npm run qwik add\" to install a server adapter'",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "start": "vite --open --mode ssr",
    "serve": "node server/entry.express.js",
    "serve.debug": "node --inspect server/entry.express.js",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.2.0",
    "@builder.io/qwik-city": "^1.2.0",
    "@types/compression": "^1.8.1",
    "@types/eslint": "^8.56.10",
    "@types/express": "^5.0.3",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-plugin-qwik": "^1.2.0",
    "postcss": "^8.5.5",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.17",
    "typescript": "5.4.5",
    "vite": "^5.4.19",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "dependencies": {
    "compression": "^1.8.0",
    "express": "^5.1.0",
    "lucide-qwik": "^1.0.0",
    "undici": "^6.19.8"
  }
}