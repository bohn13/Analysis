---
import { ShoppingCart } from 'lucide-react';
import CartButton from './CartButton';
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white shadow-sm">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center space-x-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-green-600 text-white">
          <ShoppingCart className="h-5 w-5" />
        </div>
        <span class="text-xl font-bold text-gray-900">TechStore</span>
      </a>

      <nav class="hidden md:flex items-center space-x-8">
        <a href="/" class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
          Products
        </a>
        <a href="/cart" class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
          Cart
        </a>
      </nav>

      <!-- Cart Button -->
      <CartButton client:load />
    </div>
  </div>
</header>